#!/bin/bash
# Wrapper that runs the CVM MCP server with file-based storage rooted at the
# task working directory. Pier's MCPServerConfig has no env field, so the CVM
# environment is injected here instead.
export CVM_STORAGE_TYPE=file
export CVM_DATA_DIR=/app/.cvm
export CVM_SANDBOX_ROOT=/app
exec cvm-server "$@"
