+from fastapi import FastAPI, Response
+from fastapi.testclient import TestClient
+
+
+def test_options_off_by_default():
+    app = FastAPI()
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    client = TestClient(app)
+    assert client.options("/items").status_code == 405
+
+
+def test_options_enabled_app_wide():
+    app = FastAPI(auto_options=True)
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    @app.post("/items")
+    def create_items():
+        return {"a": 1}
+
+    client = TestClient(app)
+    r = client.options("/items")
+    assert r.status_code == 200
+    body = r.json()
+    assert body["path"] == "/items"
+    assert body["methods"] == ["GET", "HEAD", "POST", "OPTIONS"]
+    assert list(body["operations"].keys()) == ["get", "post"]
+    assert r.headers["Allow"] == "GET, HEAD, POST, OPTIONS"
+
+
+def test_options_operations_match_openapi():
+    app = FastAPI(auto_options=True)
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    @app.post("/items")
+    def create_items():
+        return {"a": 1}
+
+    client = TestClient(app)
+    body = client.options("/items").json()
+    schema_path = app.openapi()["paths"]["/items"]
+    expected = {k: v for k, v in schema_path.items() if k not in ("head", "options")}
+    assert body["operations"] == expected
+
+
+def test_options_per_route_enable():
+    app = FastAPI()
+
+    @app.get("/one", auto_options=True)
+    def read_one():
+        return {"a": 1}
+
+    @app.get("/two")
+    def read_two():
+        return {"a": 1}
+
+    client = TestClient(app)
+    assert client.options("/one").status_code == 200
+    assert client.options("/two").status_code == 405
+
+
+def test_explicit_options_wins():
+    app = FastAPI(auto_options=True)
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    @app.options("/items")
+    def options_items():
+        return {"custom": True}
+
+    client = TestClient(app)
+    r = client.options("/items")
+    assert r.status_code == 200
+    assert r.json() == {"custom": True}
+
+
+def test_only_one_implicit_options_per_path():
+    app = FastAPI(auto_options=True)
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    client = TestClient(app)
+    assert client.options("/items").status_code == 200
+    assert client.options("/items").status_code == 200
+    count = len(
+        [
+            r
+            for r in app.routes
+            if getattr(r, "implicit_method", None) == "OPTIONS"
+            and getattr(r, "path_format", None) == "/items"
+        ]
+    )
+    assert count == 1
+
+
+def test_options_get_only_path_methods():
+    app = FastAPI(auto_options=True)
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    client = TestClient(app)
+    body = client.options("/items").json()
+    assert body["methods"] == ["GET", "HEAD", "OPTIONS"]
+    assert list(body["operations"].keys()) == ["get"]
+
+
+def test_options_with_auto_head_false():
+    app = FastAPI(auto_options=True, auto_head=False)
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    client = TestClient(app)
+    body = client.options("/items").json()
+    assert body["methods"] == ["GET", "OPTIONS"]
+    assert list(body["operations"].keys()) == ["get"]
+
+
+def test_implicit_options_excluded_from_schema():
+    app = FastAPI(auto_options=True)
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    TestClient(app).options("/items")
+    schema = app.openapi()
+    assert "options" not in schema["paths"]["/items"]
