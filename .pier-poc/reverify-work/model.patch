+from fastapi import FastAPI
+from fastapi.middleware.cors import CORSMiddleware
+from fastapi.responses import Response
+from fastapi.testclient import TestClient
+
+
+def test_implicit_options_returns_metadata():
+    app = FastAPI()
+
+    @app.get("/m", auto_options=True)
+    def m():
+        return {"ok": True}
+
+    client = TestClient(app)
+    response = client.options("/m")
+    assert response.status_code == 200
+    data = response.json()
+    assert set(data.keys()) == {"path", "methods", "operations"}
+
+
+def test_implicit_options_path_is_template():
+    app = FastAPI()
+
+    @app.get("/plain", auto_options=True)
+    def plain():
+        return {"ok": True}
+
+    @app.get("/items/{item_id}", auto_options=True)
+    def get_item(item_id: str):
+        return {"item_id": item_id}
+
+    client = TestClient(app)
+    assert client.options("/plain").json()["path"] == "/plain"
+    assert client.options("/items/5").json()["path"] == "/items/{item_id}"
+
+
+def test_implicit_options_methods_ordered():
+    app = FastAPI()
+
+    @app.get("/m", auto_options=True)
+    def get_m():
+        return {"ok": True}
+
+    @app.post("/m", auto_options=True)
+    def post_m():
+        return {"ok": True}
+
+    client = TestClient(app)
+    data = client.options("/m").json()
+    assert data["methods"] == ["GET", "HEAD", "POST", "OPTIONS"]
+
+
+def test_implicit_options_allow_header():
+    app = FastAPI()
+
+    @app.get("/m", auto_options=True)
+    def get_m():
+        return {"ok": True}
+
+    @app.post("/m", auto_options=True)
+    def post_m():
+        return {"ok": True}
+
+    client = TestClient(app)
+    response = client.options("/m")
+    assert response.headers["allow"] == ", ".join(response.json()["methods"])
+    assert response.headers["allow"] == "GET, HEAD, POST, OPTIONS"
+
+
+def test_implicit_options_operations_matches_openapi_minus_head_options():
+    app = FastAPI()
+
+    @app.get("/m", auto_options=True)
+    def get_m():
+        return {"ok": True}
+
+    @app.post("/m", auto_options=True)
+    def post_m():
+        return {"ok": True}
+
+    client = TestClient(app)
+    operations = client.options("/m").json()["operations"]
+    assert "head" not in operations
+    assert "options" not in operations
+    expected = {
+        method: op
+        for method, op in app.openapi()["paths"]["/m"].items()
+        if method not in ("head", "options")
+    }
+    assert operations == expected
+    assert set(operations.keys()) == {"get", "post"}
+
+
+def test_auto_options_off_by_default():
+    app = FastAPI()
+
+    @app.get("/d")
+    def d():
+        return {"ok": True}
+
+    client = TestClient(app)
+    assert client.options("/d").status_code == 405
+
+
+def test_one_implicit_options_per_path():
+    app = FastAPI()
+
+    @app.get("/multi", auto_options=True)
+    def get_multi():
+        return {"ok": True}
+
+    @app.post("/multi", auto_options=True)
+    def post_multi():
+        return {"ok": True}
+
+    client = TestClient(app)
+    client.options("/multi")  # trigger build
+    options_routes = [
+        r
+        for r in app.router.routes
+        if getattr(r, "path_format", None) == "/multi"
+        and "OPTIONS" in getattr(r, "methods", set())
+    ]
