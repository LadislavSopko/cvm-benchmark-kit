+from fastapi import FastAPI, Response
+from fastapi.testclient import TestClient
+
+
+def test_implicit_head_returns_empty_body_200():
+    app = FastAPI()
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    client = TestClient(app)
+    r = client.head("/items")
+    assert r.status_code == 200
+    assert r.content == b""
+
+
+def test_implicit_head_preserves_status_code():
+    app = FastAPI()
+
+    @app.get("/items", status_code=201)
+    def read_items():
+        return {"a": 1}
+
+    client = TestClient(app)
+    r = client.head("/items")
+    assert r.status_code == 201
+    assert r.content == b""
+
+
+def test_implicit_head_preserves_headers():
+    app = FastAPI()
+
+    @app.get("/h")
+    def read_h(response: Response):
+        response.headers["X-Custom"] = "yes"
+        return {"ok": True}
+
+    client = TestClient(app)
+    r = client.head("/h")
+    assert r.status_code == 200
+    assert r.headers["X-Custom"] == "yes"
+
+
+def test_implicit_head_preserves_validation():
+    app = FastAPI()
+
+    @app.get("/items")
+    def read_items(q: int):
+        return {"q": q}
+
+    client = TestClient(app)
+    r = client.head("/items")
+    assert r.status_code == 422
+
+
+def test_auto_head_false_disables_head():
+    app = FastAPI()
+
+    @app.get("/no", auto_head=False)
+    def read_no():
+        return {"a": 1}
+
+    client = TestClient(app)
+    r = client.head("/no")
+    assert r.status_code == 405
+
+
+def test_app_level_auto_head_false_and_per_route_override():
+    app = FastAPI(auto_head=False)
+
+    @app.get("/off")
+    def read_off():
+        return {"a": 1}
+
+    @app.get("/on", auto_head=True)
+    def read_on():
+        return {"a": 1}
+
+    client = TestClient(app)
+    assert client.head("/off").status_code == 405
+    assert client.head("/on").status_code == 200
+
+
+def test_explicit_head_wins():
+    app = FastAPI()
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    @app.head("/items")
+    def head_items(response: Response):
+        response.headers["X-Explicit"] = "1"
+        return None
+
+    client = TestClient(app)
+    r = client.head("/items")
+    assert r.status_code == 200
+    assert r.headers.get("X-Explicit") == "1"
+
+
+def test_post_only_path_has_no_implicit_head():
+    app = FastAPI()
+
+    @app.post("/p")
+    def create_p():
+        return {"a": 1}
+
+    client = TestClient(app)
+    r = client.head("/p")
+    assert r.status_code == 405
+
+
+def test_implicit_head_excluded_from_schema():
+    app = FastAPI()
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    # trigger finalization
+    TestClient(app).get("/items")
+    schema = app.openapi()
+    assert "head" not in schema["paths"]["/items"]
+
+
+def test_get_still_works_after_finalization():
+    app = FastAPI()
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    client = TestClient(app)
+    # exercise HEAD (triggers finalization) then GET
+    client.head("/items")
+    r = client.get("/items")
+    assert r.status_code == 200
+    assert r.json() == {"a": 1}
