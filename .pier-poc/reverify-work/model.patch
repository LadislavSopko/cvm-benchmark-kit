+def _first_set(*values: bool | None) -> bool | None:
+    for value in values:
+        if value is not None:
+            return value
+    return None
+
+
+def _order_methods(methods: set[str]) -> list[str]:
+    upper = {m.upper() for m in methods}
+    ordered = [m for m in METHOD_ORDER if m in upper]
+    ordered += [m for m in sorted(upper) if m not in METHOD_ORDER]
+    return ordered
+
+
+def _build_implicit_head_route(get_route: "APIRoute") -> "APIRoute":
+    head_route = copy.copy(get_route)
+    head_route.methods = {"HEAD"}
+    head_route.include_in_schema = False
+    head_route.implicit_method = "HEAD"
+    inner = get_route.get_route_handler()
+
+    async def head_app(request: Request) -> Response:
+        response = await inner(request)
+        new_response = Response(status_code=response.status_code)
+        new_response.raw_headers = list(response.raw_headers)
+        return new_response
+
+    head_route.app = request_response(head_app)
+    return head_route
+
+
+def _build_implicit_options_route(
+    path: str,
+    payload: dict[str, Any],
+    allow_header: str,
+    route_class: type["APIRoute"],
+) -> "APIRoute":
+    async def options_endpoint() -> Response:
+        return JSONResponse(content=payload, headers={"Allow": allow_header})
+
+    route = route_class(
+        path,
+        endpoint=options_endpoint,
+        methods=["OPTIONS"],
+        include_in_schema=False,
+    )
+    route.implicit_method = "OPTIONS"
+    return route
+
+
+_AUTO_HEAD_DOC = (
