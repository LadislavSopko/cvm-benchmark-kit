+import inspect
+
+import annotated_doc
+from fastapi import APIRouter, FastAPI
+from fastapi.middleware.cors import CORSMiddleware
+from fastapi.testclient import TestClient
+
+
+def _has_doc(annotation) -> bool:
+    meta = getattr(annotation, "__metadata__", None)
+    if not meta:
+        return False
+    return any(isinstance(m, annotated_doc.Doc) for m in meta)
+
+
+def test_layered_precedence_router_false_beats_app_default():
+    child = APIRouter(auto_head=False)
+    child.get("/c")(lambda: {})
+    app = FastAPI(auto_head=True)
+    app.include_router(child)
+    client = TestClient(app)
+    assert client.head("/c").status_code == 405
+
+
+def test_include_override_wins():
+    child = APIRouter()
+    child.get("/d")(lambda: {})
+    app = FastAPI(auto_head=False)
+    app.include_router(child, auto_head=True)
+    client = TestClient(app)
+    assert client.head("/d").status_code == 200
+
+
+def test_repeated_inclusion():
+    child = APIRouter()
+    child.get("/x")(lambda: {})
+    app = FastAPI()
+    app.include_router(child, prefix="/a")
+    app.include_router(child, prefix="/b")
+    client = TestClient(app)
+    assert client.head("/a/x").status_code == 200
+    assert client.head("/b/x").status_code == 200
+
+
+def test_options_method_ordering():
+    app = FastAPI(auto_options=True)
+
+    @app.get("/multi")
+    def g():
+        return {}
+
+    @app.post("/multi")
+    def p():
+        return {}
+
+    @app.put("/multi")
+    def pu():
+        return {}
+
+    @app.delete("/multi")
+    def d():
+        return {}
+
+    client = TestClient(app)
+    body = client.options("/multi").json()
+    assert body["methods"] == ["GET", "HEAD", "POST", "PUT", "DELETE", "OPTIONS"]
+
+
+def test_cors_preflight_unaffected():
+    app = FastAPI()
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    app.add_middleware(
+        CORSMiddleware, allow_origins=["*"], allow_methods=["*"], allow_headers=["*"]
+    )
+    client = TestClient(app)
+    r = client.options(
+        "/items",
+        headers={
+            "Origin": "https://example.com",
+            "Access-Control-Request-Method": "GET",
+        },
+    )
+    assert r.status_code == 200
+    assert r.headers.get("access-control-allow-origin") == "*"
+
+
+def test_docs_surface_intact():
+    app = FastAPI()
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    client = TestClient(app)
+    schema = client.get("/openapi.json")
+    assert schema.status_code == 200
+    paths = schema.json()["paths"]
+    assert "head" not in paths["/items"]
+    assert "options" not in paths["/items"]
+    assert client.get("/docs").status_code == 200
+
+
+CALLABLES = [
+    FastAPI.__init__,
+    APIRouter.__init__,
+    FastAPI.get,
+    FastAPI.put,
+    FastAPI.post,
+    FastAPI.delete,
+    FastAPI.options,
+    FastAPI.head,
+    FastAPI.patch,
+    FastAPI.trace,
+    APIRouter.get,
+    APIRouter.put,
+    APIRouter.post,
+    APIRouter.delete,
+    APIRouter.options,
+    APIRouter.head,
+    APIRouter.patch,
+    APIRouter.trace,
+    FastAPI.api_route,
+    FastAPI.add_api_route,
+    FastAPI.include_router,
+    APIRouter.api_route,
+    APIRouter.add_api_route,
+    APIRouter.include_router,
+]
+
+
+def test_all_surfaces_use_annotated_doc():
+    for fn in CALLABLES:
+        sig = inspect.signature(fn)
+        for p in ("auto_head", "auto_options"):
+            assert p in sig.parameters, (fn, p)
+            assert _has_doc(sig.parameters[p].annotation), (fn, p)
