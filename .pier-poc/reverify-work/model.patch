+class ImplicitHeadRouteMixin:
+    """Mixin that turns an `APIRoute` into an implicit HEAD route.
+
+    Runs the source GET route's handler (so dependencies, status code, headers,
+    and validation are preserved) and then drops the response body, as required
+    for HTTP HEAD responses.
+    """
+
+    path_format: str
+
+    def get_route_handler(self) -> Callable[[Request], Coroutine[Any, Any, Response]]:
+        handler = super().get_route_handler()  # type: ignore[misc]
+
+        async def head_handler(request: Request) -> Response:
+            request.scope["fastapi_implicit_method"] = ("head", self.path_format)
+            response = await handler(request)
+            # Preserve status code and headers (including content-length) but
+            # send no body, as required for HEAD responses.
+            if hasattr(response, "body"):
+                response.body = b""
+            return response
+
+        return head_handler
+
+
+_implicit_head_route_classes: dict[type, type] = {}
+
+
+def _implicit_head_route_class(base: type) -> type:
+    cls = _implicit_head_route_classes.get(base)
+    if cls is None:
+        cls = type(
+            "ImplicitHead" + base.__name__, (ImplicitHeadRouteMixin, base), {}
+        )
+        _implicit_head_route_classes[base] = cls
+    return cls
+
+
+def build_implicit_head_route(source: APIRoute) -> APIRoute:
+    """Build an implicit HEAD route from a GET route, preserving its class."""
+    route_class = _implicit_head_route_class(type(source))
+    route: APIRoute = route_class(
+        source.path,
+        source.endpoint,
+        response_model=source.response_model,
+        status_code=source.status_code,
+        tags=list(source.tags),
+        dependencies=list(source.dependencies),
+        summary=source.summary,
+        description=source.description,
+        response_description=source.response_description,
