+    "`HEAD` request runs the same dependencies, validation, status code, and "
+    "headers as the `GET` operation but returns an empty body. An explicit "
+    "`HEAD` operation always takes precedence."
+)
+_AUTO_OPTIONS_DOC = (
+    "Whether to automatically provide an implicit HTTP `OPTIONS` operation for "
+    "the path. When enabled (disabled by default), an `OPTIONS` request returns "
+    "a 200 JSON response with the path, its ordered available methods, and its "
+    "operations (matching the OpenAPI for that path, excluding `HEAD` and "
+    "`OPTIONS`), plus an `Allow` header. An explicit `OPTIONS` operation always "
+    "takes precedence."
+)
+AutoHeadParam = Annotated[bool | None, Doc(_AUTO_HEAD_DOC)]
+AutoOptionsParam = Annotated[bool | None, Doc(_AUTO_OPTIONS_DOC)]
