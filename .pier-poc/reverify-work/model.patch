+import inspect
+
+import annotated_doc
+from fastapi import APIRouter
+
+
+def _has_doc(annotation) -> bool:
+    meta = getattr(annotation, "__metadata__", None)
+    if not meta:
+        return False
+    return any(isinstance(m, annotated_doc.Doc) for m in meta)
+
+
+def test_apirouter_default_auto_values():
+    r = APIRouter()
+    assert r.auto_head is None
+    assert r.auto_options is None
+
+
+def test_apirouter_explicit_auto_values():
+    r = APIRouter(auto_head=False, auto_options=True)
+    assert r.auto_head is False
+    assert r.auto_options is True
+
+
+def test_decorator_raw_none_when_omitted():
+    r = APIRouter()
+    r.get("/x")(lambda: None)
+    assert r.routes[-1].auto_head is None
+    assert r.routes[-1].auto_options is None
+
+
+def test_decorator_explicit_values():
+    r = APIRouter()
+    r.get("/y", auto_head=True, auto_options=True)(lambda: None)
+    assert r.routes[-1].auto_head is True
+    assert r.routes[-1].auto_options is True
+
+
+def test_add_api_route_explicit_value():
+    r = APIRouter()
+    r.add_api_route("/z", lambda: None, methods=["POST"], auto_options=True)
+    assert r.routes[-1].auto_options is True
+    assert r.routes[-1].auto_head is None
+
+
+def test_apirouter_surfaces_use_annotated_doc():
+    callables = [
+        APIRouter.__init__,
+        APIRouter.get,
+        APIRouter.post,
+        APIRouter.api_route,
+        APIRouter.add_api_route,
+    ]
+    for fn in callables:
+        sig = inspect.signature(fn)
+        for p in ("auto_head", "auto_options"):
+            assert p in sig.parameters, (fn, p)
+            assert _has_doc(sig.parameters[p].annotation), (fn, p)
