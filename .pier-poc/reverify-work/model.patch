+    mw = ImplicitMethodTrackingMiddleware(_app())
+    client = TestClient(mw)
+    client.head("/p")
+    client.options("/p")
+    snapshot = mw.reset_stats()
+    assert snapshot == {"/p": {"head_hits": 1, "options_hits": 1}}
+    assert mw.get_stats() == {}
+
+
+def test_non_http_scopes_ignored():
+    app = FastAPI()
+
+    @app.get("/p")
+    def p():
+        return {"ok": True}
+
+    @app.websocket("/ws")
+    async def ws(websocket: WebSocket):
+        await websocket.accept()
+        await websocket.send_text("hi")
+        await websocket.close()
+
+    mw = ImplicitMethodTrackingMiddleware(app)
+    client = TestClient(mw)
+    with client.websocket_connect("/ws") as connection:
+        assert connection.receive_text() == "hi"
+    assert mw.get_stats() == {}
+
+
+def test_implicit_routes_excluded_from_openapi():
+    def p():
+        return {"ok": True}
+
+    app = FastAPI()
+    app.get("/p", auto_options=True)(p)
+
+    # same endpoint, no implicit flags, so the GET operation is identical
+    baseline = FastAPI()
+    baseline.get("/p")(p)
+
+    client = TestClient(app)
+    client.options("/p")  # trigger build (synthesizes implicit HEAD + OPTIONS)
+    paths = app.openapi()["paths"]
+    assert set(paths["/p"].keys()) == {"get"}
+    assert "head" not in paths["/p"]
+    assert "options" not in paths["/p"]
+    # the real GET operation is unchanged vs a baseline app without the flags
+    assert paths["/p"]["get"] == baseline.openapi()["paths"]["/p"]["get"]
+
+
+def test_signatures_expose_new_params():
+    get_params = inspect.signature(FastAPI.get).parameters
+    assert "auto_head" in get_params
+    assert "auto_options" in get_params
+    init_params = inspect.signature(APIRouter.__init__).parameters
+    assert "auto_head" in init_params
+    assert "auto_options" in init_params
