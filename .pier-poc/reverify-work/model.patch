+def test_app_level_auto_options_with_route_override():
+    app = FastAPI(auto_options=True)
+
+    @app.get("/a")
+    def a():
+        return {"ok": True}
+
+    @app.get("/b", auto_options=False)
+    def b():
+        return {"ok": True}
+
+    client = TestClient(app)
+    assert client.options("/a").status_code == 200  # enabled by app
+    assert client.options("/b").status_code == 405  # route disables
+
+
+def test_explicit_options_wins():
+    app = FastAPI()
+
+    @app.get("/x", auto_options=True)
+    def getx():
+        return {"ok": True}
+
+    @app.options("/x")
+    def optx():
+        return Response(headers={"x-explicit": "1"})
+
+    client = TestClient(app)
+    response = client.options("/x")
+    assert response.status_code == 200
+    assert response.headers.get("x-explicit") == "1"
+    # the explicit handler returns no metadata JSON body
+    assert response.content == b"" or "path" not in response.json()
+
