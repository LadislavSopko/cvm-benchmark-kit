index 000000000..635742642
--- /dev/null
+++ b/fastapi/middleware/methods.py
@@ -0,0 +1,44 @@
+import copy
+
+from starlette.types import ASGIApp, Receive, Scope, Send
+
+
+class ImplicitMethodTrackingMiddleware:
+    """Pure-ASGI middleware that counts hits to implicit HEAD/OPTIONS routes.
+
+    FastAPI's implicit HEAD and OPTIONS route handlers set
+    ``scope["fastapi_implicit_method"] = ("head" | "options", full_path)`` while
+    handling a request. This middleware reads that marker after the downstream
+    app has run (the same ``scope`` dict is mutated in place) and increments a
+    per-path counter. Only implicit hits are tracked; explicit routes and normal
+    methods leave no marker and are ignored, as are non-HTTP scopes.
+    """
+
+    def __init__(self, app: ASGIApp) -> None:
+        self.app = app
+        self._stats: dict[str, dict[str, int]] = {}
+
+    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None:
+        if scope["type"] != "http":
+            await self.app(scope, receive, send)
+            return
+        await self.app(scope, receive, send)
+        marker = scope.get("fastapi_implicit_method")
+        if not marker:
+            return
+        kind, full_path = marker
+        entry = self._stats.setdefault(
+            full_path, {"head_hits": 0, "options_hits": 0}
+        )
+        if kind == "head":
+            entry["head_hits"] += 1
+        elif kind == "options":
+            entry["options_hits"] += 1
+
+    def get_stats(self) -> dict[str, dict[str, int]]:
+        return copy.deepcopy(self._stats)
+
+    def reset_stats(self) -> dict[str, dict[str, int]]:
+        snapshot = copy.deepcopy(self._stats)
+        self._stats = {}
+        return snapshot
