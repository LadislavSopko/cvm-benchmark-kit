@@ -0,0 +1,74 @@
+from fastapi import FastAPI, Response
+from fastapi.middleware.methods import ImplicitMethodTrackingMiddleware
+from fastapi.testclient import TestClient
+
+
+def _build_app():
+    app = FastAPI(auto_options=True)
+
+    @app.get("/items")
+    def read_items():
+        return {"a": 1}
+
+    return app
+
+
+def test_tracks_implicit_head_and_options_hits():
+    mw = ImplicitMethodTrackingMiddleware(_build_app())
+    client = TestClient(mw)
+    client.head("/items")
+    client.head("/items")
+    client.options("/items")
+    assert mw.get_stats() == {"/items": {"head_hits": 2, "options_hits": 1}}
+
+
+def test_normal_get_not_counted():
+    mw = ImplicitMethodTrackingMiddleware(_build_app())
+    client = TestClient(mw)
+    client.get("/items")
+    assert mw.get_stats() == {}
+
+
+def test_explicit_head_and_options_not_counted():
+    app = FastAPI()
+
+    @app.head("/x")
+    def head_x():
+        return None
+
+    @app.options("/x")
+    def options_x():
+        return {"ok": True}
+
+    mw = ImplicitMethodTrackingMiddleware(app)
+    client = TestClient(mw)
+    client.head("/x")
+    client.options("/x")
+    assert mw.get_stats() == {}
+
+
+def test_get_stats_returns_deep_copy():
+    mw = ImplicitMethodTrackingMiddleware(_build_app())
+    client = TestClient(mw)
+    client.head("/items")
+    stats = mw.get_stats()
+    stats["/items"]["head_hits"] = 999
+    stats["injected"] = {"head_hits": 1, "options_hits": 1}
+    assert mw.get_stats() == {"/items": {"head_hits": 1, "options_hits": 0}}
+
+
+def test_reset_stats_returns_snapshot_and_clears():
+    mw = ImplicitMethodTrackingMiddleware(_build_app())
+    client = TestClient(mw)
+    client.head("/items")
+    client.options("/items")
+    snapshot = mw.reset_stats()
+    assert snapshot == {"/items": {"head_hits": 1, "options_hits": 1}}
+    assert mw.get_stats() == {}
+
+
+def test_non_http_scope_ignored():
+    mw = ImplicitMethodTrackingMiddleware(_build_app())
+    with TestClient(mw) as client:
+        client.head("/items")
+    assert mw.get_stats() == {"/items": {"head_hits": 1, "options_hits": 0}}
