+import inspect
+import typing
+
+from annotated_doc import Doc
+from fastapi import APIRouter
+from fastapi.datastructures import DefaultPlaceholder
+from fastapi.routing import APIRoute
+
+
+def ep():
+    return {"ok": True}
+
+
+def _has_doc(func, param_name):
+    annotation = inspect.signature(func).parameters[param_name].annotation
+    metadata = typing.get_args(annotation)[1:]
+    return any(isinstance(m, Doc) for m in metadata)
+
+
+def test_apiroute_auto_omitted_is_placeholder():
+    route = APIRoute("/x", ep, methods=["GET"])
+    assert isinstance(route.auto_head, DefaultPlaceholder)
+    assert isinstance(route.auto_options, DefaultPlaceholder)
+
+
+def test_apiroute_auto_head_explicit_false():
+    route = APIRoute("/x", ep, methods=["GET"], auto_head=False)
+    assert route.auto_head is False
+
+
+def test_apirouter_defaults():
+    r = APIRouter()
+    assert r.auto_head is True
+    assert r.auto_options is False
+    assert r._implicit_generated is False
+
+
+def test_apirouter_auto_head_false():
+    assert APIRouter(auto_head=False).auto_head is False
+
+
+def test_decorator_forwards_auto_options():
+    r = APIRouter()
+    r.get("/x", auto_options=True)(lambda: 1)
+    route = r.routes[-1]
+    assert route.auto_options is True
+    assert isinstance(route.auto_head, DefaultPlaceholder)
+
+
+def test_add_api_route_keeps_raw_auto_head():
+    r = APIRouter()
+    r.add_api_route("/x", ep, methods=["GET"], auto_head=False)
+    assert r.routes[-1].auto_head is False
+
+
+def test_apirouter_get_auto_head_has_doc():
+    assert _has_doc(APIRouter.get, "auto_head")
+    assert _has_doc(APIRouter.get, "auto_options")
