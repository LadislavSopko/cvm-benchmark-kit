+from fastapi import APIRouter, Depends, FastAPI, HTTPException
+from fastapi.responses import Response
+from fastapi.testclient import TestClient
+
+
+def test_implicit_head_returns_empty_body_same_content_type():
+    app = FastAPI()
+
+    @app.get("/items")
+    def read_items():
+        return {"x": 1}
+
+    client = TestClient(app)
+    get_resp = client.get("/items")
+    head_resp = client.head("/items")
+    assert head_resp.status_code == 200
+    assert head_resp.content == b""
+    assert head_resp.headers["content-type"] == get_resp.headers["content-type"]
+
+
+def test_implicit_head_preserves_dependencies():
+    app = FastAPI()
+
+    def guard():
+        raise HTTPException(status_code=400, detail="nope")
+
+    @app.get("/items", dependencies=[Depends(guard)])
+    def read_items():
+        return {"x": 1}
+
+    client = TestClient(app)
+    assert client.head("/items").status_code == 400
+
+
+def test_implicit_head_preserves_validation():
+    app = FastAPI()
+
+    @app.get("/items")
+    def read_items(q: int):
+        return {"q": q}
+
+    client = TestClient(app)
+    assert client.head("/items").status_code == 422
+
+
+def test_explicit_head_wins():
+    app = FastAPI()
+
+    @app.get("/items")
+    def read_items():
+        return {"x": 1}
+
+    @app.head("/items")
+    def head_items():
+        return Response(status_code=418)
+
+    client = TestClient(app)
+    assert client.head("/items").status_code == 418
+
+
+def test_route_level_auto_head_false_disables():
+    app = FastAPI()
+
+    @app.get("/items", auto_head=False)
+    def read_items():
+        return {"x": 1}
+
+    client = TestClient(app)
+    assert client.head("/items").status_code == 405
+
+
+def test_app_level_auto_head_false_disables():
+    app = FastAPI(auto_head=False)
+
+    @app.get("/items")
+    def read_items():
+        return {"x": 1}
+
+    client = TestClient(app)
+    assert client.head("/items").status_code == 405
+
+
+def test_included_router_gets_implicit_head():
+    app = FastAPI()
+    router = APIRouter()
+
+    @router.get("/items")
+    def read_items():
+        return {"x": 1}
+
+    app.include_router(router)
+    client = TestClient(app)
+    assert client.head("/items").status_code == 200
+
+
+def test_openapi_has_no_head_key():
+    app = FastAPI()
+
+    @app.get("/items")
+    def read_items():
+        return {"x": 1}
+
+    # trigger generation
+    TestClient(app).head("/items")
+    schema = app.openapi()
+    assert "head" not in schema["paths"]["/items"]
