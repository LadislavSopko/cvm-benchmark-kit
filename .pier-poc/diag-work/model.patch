+# Canonical ordering for HTTP methods used by implicit OPTIONS responses.
+METHOD_ORDER = ["GET", "HEAD", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "TRACE"]
+
+
+def order_methods(methods: set[str] | list[str]) -> list[str]:
+    """Order HTTP methods by the canonical `METHOD_ORDER`.
+
+    Unknown methods are appended after the known ones, sorted alphabetically.
+    """
+    known = [m for m in METHOD_ORDER if m in methods]
+    extra = sorted(m for m in methods if m not in METHOD_ORDER)
+    return known + extra
+
+
+def _first_set(*values: Any) -> Any:
+    """Return the first value that is not a `DefaultPlaceholder` (omitted) marker.
+
+    If every value is a `DefaultPlaceholder`, the last value is returned.
+    """
+    for value in values:
+        if not isinstance(value, DefaultPlaceholder):
+            return value
+    return values[-1]
+
+
+def _resolve_auto(value: Any, default: bool) -> bool:
+    """Resolve an `auto_head`/`auto_options` value against a concrete default."""
+    if isinstance(value, DefaultPlaceholder):
+        return default
+    return bool(value)
+
+
+# Reusable, documented parameter annotations for the new implicit-method controls.
+# Omitted values (`Default(None)`) inherit from the nearest non-omitted setting
+# (route, include, router/app) per the precedence rules.
+AutoHeadParam = Annotated[
+    bool | DefaultPlaceholder,
+    Doc(
+        """
+        Whether to generate an implicit `HEAD` operation for a `GET` *path
+        operation*.
+
+        The implicit `HEAD` reuses the `GET` route's dependencies, status code,
+        headers, and validation behavior, but returns no body. Defaults on for
+        `GET` routes; when omitted the value is inherited from the router/app.
+        """
+    ),
+]
+AutoOptionsParam = Annotated[
+    bool | DefaultPlaceholder,
+    Doc(
+        """
+        Whether to generate an implicit `OPTIONS` response exposing path metadata
+        (`path`, ordered `methods`, and `operations`).
+
+        Defaults off; when omitted the value is inherited from the router/app.
+        """
+    ),
+]
+
+
+def _make_head_app(original_app: ASGIApp, path: str) -> ASGIApp:
+    """Wrap a GET route's ASGI app to serve an implicit `HEAD`: same handling,
+    no response body. Also flags the scope so middleware can track the hit."""
+
+    async def head_app(scope: Scope, receive: Receive, send: Send) -> None:
+        scope["fastapi_implicit_method"] = "head"
+        scope["fastapi_implicit_path"] = path
+
+        async def send_wrapper(message: Any) -> None:
+            if message["type"] == "http.response.body":
+                message = dict(message)
+                message["body"] = b""
+                message["more_body"] = False
+            await send(message)
+
+        await original_app(scope, receive, send_wrapper)
+
+    return head_app
+
+
+def _make_options_endpoint(
+    path: str, ordered_methods: list[str]
+) -> Callable[[Request], Coroutine[Any, Any, Response]]:
+    """Build the endpoint for an implicit `OPTIONS` response that exposes path
+    metadata (`path`, ordered `methods`, and `operations`) and an `Allow` header."""
+
+    async def options_endpoint(request: Request) -> Response:
+        request.scope["fastapi_implicit_method"] = "options"
+        request.scope["fastapi_implicit_path"] = path
+        schema = request.app.openapi()
+        path_item = schema.get("paths", {}).get(path) or {}
+        operations = {
+            k: v
+            for k, v in path_item.items()
+            if k.lower() not in ("head", "options")
+        }
+        content = {
+            "path": path,
+            "methods": ordered_methods,
+            "operations": operations,
+        }
+        return JSONResponse(
+            content,
+            status_code=200,
+            headers={"Allow": ", ".join(ordered_methods)},
+        )
+
+    return options_endpoint
+
 
