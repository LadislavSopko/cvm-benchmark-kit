+import inspect
+import typing
+
+from annotated_doc import Doc
+from fastapi import APIRouter, FastAPI
+from fastapi.middleware.methods import ImplicitMethodTrackingMiddleware
+from fastapi.testclient import TestClient
+
+
+def _build(auto_options=False):
+    app = FastAPI()
+
+    @app.get("/items", auto_options=auto_options)
+    def read_items():
+        return {"x": 1}
+
+    mw = ImplicitMethodTrackingMiddleware(app)
+    return app, mw
+
+
+def test_head_hit_tracked():
+    _, mw = _build()
+    client = TestClient(mw)
+    client.head("/items")
+    stats = mw.get_stats()
+    assert stats["/items"]["head_hits"] == 1
+    assert stats["/items"]["options_hits"] == 0
+
+
+def test_options_hit_tracked():
+    _, mw = _build(auto_options=True)
+    client = TestClient(mw)
+    client.options("/items")
+    assert mw.get_stats()["/items"]["options_hits"] == 1
+
+
+def test_explicit_get_not_tracked():
+    _, mw = _build()
+    client = TestClient(mw)
+    client.get("/items")
+    assert mw.get_stats() == {}
+
+
+def test_reset_stats_snapshot_and_clear():
+    _, mw = _build()
+    client = TestClient(mw)
+    client.head("/items")
+    snapshot = mw.reset_stats()
+    assert snapshot["/items"]["head_hits"] == 1
+    assert mw.get_stats() == {}
+
+
+def test_non_http_scope_not_tracked():
+    _, mw = _build()
+    with TestClient(mw):
+        pass
+    assert mw.get_stats() == {}
+
+
+def test_import_middleware():
+    from fastapi.middleware.methods import ImplicitMethodTrackingMiddleware as M
+
+    assert M is ImplicitMethodTrackingMiddleware
+
+
+def _has_doc(func, param_name):
+    annotation = inspect.signature(func).parameters[param_name].annotation
+    metadata = typing.get_args(annotation)[1:]
+    return any(isinstance(m, Doc) for m in metadata)
+
+
+def test_docs_surface_on_public_signatures():
+    for func in (FastAPI.get, APIRouter.get):
+        assert _has_doc(func, "auto_head")
+        assert _has_doc(func, "auto_options")
+    for func in (FastAPI.include_router, APIRouter.include_router):
+        assert _has_doc(func, "auto_head")
+        assert _has_doc(func, "auto_options")
