new file mode 100644
index 000000000..7d71257b3
--- /dev/null
+++ b/fastapi/middleware/methods.py
@@ -0,0 +1,38 @@
+import copy
+from typing import Any
+
+from starlette.types import ASGIApp, Receive, Scope, Send
+
+
+class ImplicitMethodTrackingMiddleware:
+    """ASGI middleware that counts hits to *implicit* HEAD and OPTIONS routes.
+
+    Implicit route handlers signal a hit by setting `scope["fastapi_implicit_method"]`
+    (``"head"`` or ``"options"``) and `scope["fastapi_implicit_path"]`. Only those
+    implicit hits are tracked; explicit/normal routes and non-HTTP scopes are ignored.
+    """
+
+    def __init__(self, app: ASGIApp) -> None:
+        self.app = app
+        self._stats: dict[str, dict[str, int]] = {}
+
+    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None:
+        if scope["type"] != "http":
+            await self.app(scope, receive, send)
+            return
+        await self.app(scope, receive, send)
+        method = scope.get("fastapi_implicit_method")
+        if method in ("head", "options"):
+            path = scope.get("fastapi_implicit_path", scope.get("path", ""))
+            entry = self._stats.setdefault(path, {"head_hits": 0, "options_hits": 0})
+            entry[f"{method}_hits"] += 1
+
+    def get_stats(self) -> dict[str, dict[str, int]]:
+        """Return a deep copy of the implicit-hit counters."""
+        return copy.deepcopy(self._stats)
+
+    def reset_stats(self) -> dict[str, dict[str, int]]:
+        """Return a deep-copied snapshot of the counters and clear them."""
+        snapshot = copy.deepcopy(self._stats)
+        self._stats = {}
+        return snapshot
