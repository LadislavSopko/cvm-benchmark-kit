+import inspect
+import typing
+
+from annotated_doc import Doc
+from fastapi import APIRouter
+
+
+def ep():
+    return {"ok": True}
+
+
+def _last_route(host):
+    return host.routes[-1]
+
+
+def _has_doc(func, param_name):
+    annotation = inspect.signature(func).parameters[param_name].annotation
+    metadata = typing.get_args(annotation)[1:]
+    return any(isinstance(m, Doc) for m in metadata)
+
+
+def test_subrouter_default_used():
+    r = APIRouter()
+    r.get("/x")(ep)
+    host = APIRouter()
+    host.include_router(r)
+    assert _last_route(host).auto_head is True
+
+
+def test_route_level_wins():
+    r = APIRouter()
+    r.get("/x", auto_head=False)(ep)
+    host = APIRouter()
+    host.include_router(r, auto_head=True)
+    assert _last_route(host).auto_head is False
+
+
+def test_include_level_used_when_route_omitted():
+    r = APIRouter(auto_head=True)
+    r.get("/x")(ep)
+    host = APIRouter()
+    host.include_router(r, auto_head=False)
+    assert _last_route(host).auto_head is False
+
+
+def test_router_level_used_when_route_and_include_omitted():
+    r = APIRouter(auto_head=False)
+    r.get("/x")(ep)
+    host = APIRouter()
+    host.include_router(r)
+    assert _last_route(host).auto_head is False
+
+
+def test_auto_options_precedence():
+    # route > include > router
+    r1 = APIRouter()
+    r1.get("/a", auto_options=True)(ep)
+    host1 = APIRouter()
+    host1.include_router(r1, auto_options=False)
+    assert _last_route(host1).auto_options is True
+
+    r2 = APIRouter(auto_options=False)
+    r2.get("/b")(ep)
+    host2 = APIRouter()
+    host2.include_router(r2, auto_options=True)
+    assert _last_route(host2).auto_options is True
+
+    r3 = APIRouter(auto_options=True)
+    r3.get("/c")(ep)
+    host3 = APIRouter()
+    host3.include_router(r3)
+    assert _last_route(host3).auto_options is True
+
+
+def test_include_router_doc_metadata():
+    assert _has_doc(APIRouter.include_router, "auto_head")
+    assert _has_doc(APIRouter.include_router, "auto_options")
