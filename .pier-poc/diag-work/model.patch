+import asyncio
+
+from fastapi.middleware.methods import ImplicitMethodTrackingMiddleware
+
+
+async def _noop_receive():
+    return {"type": "http.request"}
+
+
+async def _noop_send(message):
+    return None
+
+
+def _run(coro):
+    loop = asyncio.new_event_loop()
+    try:
+        return loop.run_until_complete(coro)
+    finally:
+        loop.close()
+
+
+def _make_inner(method=None, path="/x"):
+    async def app(scope, receive, send):
+        if method is not None:
+            scope["fastapi_implicit_method"] = method
+            scope["fastapi_implicit_path"] = path
+
+    return app
+
+
+def test_non_http_scope_passthrough_not_tracked():
+    called = {}
+
+    async def app(scope, receive, send):
+        called["yes"] = True
+
+    mw = ImplicitMethodTrackingMiddleware(app)
+    _run(mw({"type": "lifespan"}, _noop_receive, _noop_send))
+    assert called.get("yes") is True
+    assert mw.get_stats() == {}
+
+
+def test_head_hit_increments():
+    mw = ImplicitMethodTrackingMiddleware(_make_inner("head", "/x"))
+    _run(mw({"type": "http", "path": "/x"}, _noop_receive, _noop_send))
+    stats = mw.get_stats()
+    assert stats["/x"]["head_hits"] == 1
+    assert stats["/x"]["options_hits"] == 0
+
+
+def test_options_hit_increments():
+    mw = ImplicitMethodTrackingMiddleware(_make_inner("options", "/x"))
+    _run(mw({"type": "http", "path": "/x"}, _noop_receive, _noop_send))
+    stats = mw.get_stats()
+    assert stats["/x"]["options_hits"] == 1
+    assert stats["/x"]["head_hits"] == 0
+
+
+def test_no_flag_not_tracked():
+    mw = ImplicitMethodTrackingMiddleware(_make_inner(None, "/x"))
+    _run(mw({"type": "http", "path": "/x"}, _noop_receive, _noop_send))
+    assert mw.get_stats() == {}
+
+
+def test_two_head_hits_accumulate():
+    mw = ImplicitMethodTrackingMiddleware(_make_inner("head", "/x"))
+    _run(mw({"type": "http", "path": "/x"}, _noop_receive, _noop_send))
+    _run(mw({"type": "http", "path": "/x"}, _noop_receive, _noop_send))
+    assert mw.get_stats()["/x"]["head_hits"] == 2
+
+
+def test_get_stats_is_deep_copy():
+    mw = ImplicitMethodTrackingMiddleware(_make_inner("head", "/x"))
+    _run(mw({"type": "http", "path": "/x"}, _noop_receive, _noop_send))
+    stats = mw.get_stats()
+    stats["/x"]["head_hits"] = 999
+    stats["new"] = {"head_hits": 5, "options_hits": 5}
+    assert mw.get_stats()["/x"]["head_hits"] == 1
+    assert "new" not in mw.get_stats()
+
+
+def test_reset_stats_returns_snapshot_and_clears():
+    mw = ImplicitMethodTrackingMiddleware(_make_inner("head", "/x"))
+    _run(mw({"type": "http", "path": "/x"}, _noop_receive, _noop_send))
+    snapshot = mw.reset_stats()
+    assert snapshot["/x"]["head_hits"] == 1
+    assert mw.get_stats() == {}
