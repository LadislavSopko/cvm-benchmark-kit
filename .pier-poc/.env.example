# Copy this file to `.env` (same folder) and fill in your token.
#   cp .pier-poc/.env.example .pier-poc/.env
# The token comes from `claude setup-token` (uses your Claude subscription, not API).
# `.env` is gitignored — your token never gets committed.

CLAUDE_CODE_OAUTH_TOKEN=

# Optional: override the model pier passes to claude-code.
# Leave empty to use whatever is in config.yaml (anthropic/claude-opus-4-8).
# Example alternative: anthropic/claude-opus-4-7
PIER_MODEL=
